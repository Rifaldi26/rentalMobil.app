APP_NAME="RentWheels"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

# ─── Database ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=rental_mobil
DB_USERNAME=root
DB_PASSWORD=

# ─── Queue & Cache ─────────────────────────────────────────────
# Gunakan database untuk development, redis untuk production
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=log        # ganti ke smtp/mailgun/resend di production
MAIL_FROM_ADDRESS="noreply@rentalwheels.id"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Broadcasting (pilih SATU: reverb atau pusher) ─────────────
BROADCAST_CONNECTION=reverb
VITE_BROADCAST_DRIVER=reverb

# Pusher (cloud, berbayar) — isi jika tidak pakai Reverb
BROADCAST_CONNECTION=pusher
VITE_BROADCAST_DRIVER=pusher
PUSHER_APP_ID=2160605
PUSHER_APP_KEY=ff4a0c2d74490db66335
PUSHER_APP_SECRET=28468450658e0bb2bf23
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap1
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─── Payment Gateway (Midtrans) ────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# ─── Redis (opsional, direkomendasikan untuk production) ────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ─── Filesystem ────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
